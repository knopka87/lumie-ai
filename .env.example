# Database
# PostgreSQL connection string
# Use port 5433 when running PostgreSQL via docker-compose (default)
# Use port 5432 if you have PostgreSQL running locally
DATABASE_URL=postgres://lumie:lumie_secret@localhost:5433/lumie

# Gemini API
# Required for AI API calls
GEMINI_API_KEY=your_gemini_api_key_here

# Application URL
APP_URL=http://localhost:3000

# Google OAuth (optional, enables Google Sign-In)
# Without these, the app will use demo mode
# To get credentials:
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add http://localhost:3000 to authorized JavaScript origins
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Docker (used by docker-compose)
DB_PASSWORD=lumie_secret
